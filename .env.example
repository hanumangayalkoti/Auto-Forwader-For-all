# ===== TELEGRAM =====
BOT_TOKEN=your_bot_token_here
API_ID=your_api_id_here
API_HASH=your_api_hash_here
OWNER_ID=your_telegram_user_id_here

# ===== DATABASE =====
# Railway PostgreSQL URL milega deployment ke baad
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ===== RAZORPAY =====
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# Razorpay dashboard mein webhook secret set karna padega
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ===== ENCRYPTION =====
# Python mein generate karo: from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())
FERNET_KEY=your_fernet_key_here

# ===== SERVER =====
# Railway automatically PORT set karta hai — yahan change mat karo
PORT=8080
